# ============================================================================
# laravel-rebel-channel-telegram — environment variables
# ============================================================================

# --- Telegram bot (from @BotFather) -----------------------------------------
# 1. Open Telegram and start a chat with @BotFather (https://t.me/BotFather).
# 2. Send /newbot, pick a name and a username (must end in "bot").
# 3. BotFather replies with your token: "123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxx".
TELEGRAM_BOT_TOKEN=123456789:AAExxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Getting a chat_id ------------------------------------------------------
# The "recipient" in Telegram is a chat_id, not a phone number.
#  - For a 1:1 chat: have the user send /start to your bot, then call
#    https://api.telegram.org/bot<token>/getUpdates and read result[].message.chat.id.
#  - For a group: add the bot to the group, post a message, and read the (negative)
#    chat.id from getUpdates.
#  - For a channel: add the bot as an admin and use "@channelusername" or its id.
# Optional fallback chat_id (e.g. a security-alerts group):
TELEGRAM_DEFAULT_CHAT_ID=

# Auto-register the Telegram delivery channel (needs TELEGRAM_BOT_TOKEN above).
REBEL_TELEGRAM_REGISTER=true

# Message formatting: empty (plain text), MarkdownV2 or HTML.
TELEGRAM_PARSE_MODE=

# HTTP timeout in seconds for the Bot API.
TELEGRAM_TIMEOUT=10

# --- Live test suite (opt-in: SENDS A REAL MESSAGE) -------------------------
# Set to 1 and provide a test chat to run tests/Live against the real Bot API.
REBEL_TELEGRAM_LIVE=0
TELEGRAM_TEST_CHAT_ID=
